# Documentation: https://docs.searxng.org/admin/installation-docker.html
# Settings Documentation: https://docs.searxng.org/admin/settings/index.html

# Use a specific version tag. E.g. "latest" or "2026.4.13-ee66b070a".
SEARXNG_VERSION=2026.4.13-ee66b070a

# Port for SearXNG from outside the container
SEARXNG_PORT=8081

# MCP Search & Fetch Configuration
MCP_SEARCH_FETCH_SEARXNG_BASE_URL=http://searxng:8080
MCP_SEARCH_FETCH_MCP_HOST=0.0.0.0
MCP_SEARCH_FETCH_MCP_PORT=8000
MCP_SEARCH_FETCH_LOG_LEVEL=INFO
MCP_SEARCH_FETCH_LOG_FILE=mcp_search_fetch.log
